# 应用基础配置
APP_ENV=development
APP_NAME=webmail-mvp
APP_SECRET_KEY=change-me-in-local-env
LOG_LEVEL=INFO

# Webmail 公网入口
PUBLIC_BASE_URL=https://mail.mdaemon.cc
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 数据库与缓存
POSTGRES_DB=webmail
POSTGRES_USER=webmail
POSTGRES_PASSWORD=webmail_dev_password
DATABASE_URL=postgresql+psycopg://webmail:webmail_dev_password@postgres:5432/webmail
REDIS_URL=redis://redis:6379/0

# 邮件服务器
MAIL_IMAP_HOST=14.103.117.188
MAIL_IMAP_PORT=143
MAIL_IMAP_SSL=false
MAIL_IMAP_STARTTLS=false
MAIL_SMTP_HOST=14.103.117.188
MAIL_SMTP_PORT=25
MAIL_SMTP_SSL=false
MAIL_SMTP_STARTTLS=false
MAIL_DIRECTORY_BACKEND=postgres
MAIL_DIRECTORY_SQLITE_PATH=/var/vmail/vmail.db
MAIL_DIRECTORY_PASSWORD_MODE=plain

# 会话与附件
SESSION_TTL_SECONDS=28800
ATTACHMENT_MAX_MB=9
TEMP_ATTACHMENT_TTL_SECONDS=86400
ATTACHMENT_PREVIEW_CACHE_TTL_SECONDS=604800
ATTACHMENT_PREVIEW_CACHE_MAX_MB=1024

# 新邮件系统通知（Web Push + 后端轮询）
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_CLAIMS_SUBJECT=mailto:admin@example.com
MAIL_NOTIFICATION_POLL_ENABLED=false
MAIL_NOTIFICATION_POLL_INTERVAL_SECONDS=45
MAIL_NOTIFICATION_BATCH_SIZE=10
MAIL_NOTIFICATION_IMAP_TIMEOUT_SECONDS=15
