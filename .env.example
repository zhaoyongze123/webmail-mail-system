# 应用基础配置
APP_ENV=development
APP_NAME=webmail-mvp
APP_SECRET_KEY=change-me-in-local-env
LOG_LEVEL=INFO

# Webmail 公网入口
PUBLIC_BASE_URL=https://mail.mdaemon.cc
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 数据库与缓存
POSTGRES_DB=webmail
POSTGRES_USER=webmail
POSTGRES_PASSWORD=webmail_dev_password
DATABASE_URL=postgresql://webmail:webmail_dev_password@postgres:5432/webmail
REDIS_URL=redis://redis:6379/0

# 邮件服务器
MAIL_IMAP_HOST=14.103.117.188
MAIL_IMAP_PORT=143
MAIL_IMAP_SSL=false
MAIL_IMAP_STARTTLS=false
MAIL_SMTP_HOST=14.103.117.188
MAIL_SMTP_PORT=25
MAIL_SMTP_SSL=false
MAIL_SMTP_STARTTLS=false

# 会话与附件
SESSION_TTL_SECONDS=28800
ATTACHMENT_MAX_MB=9
TEMP_ATTACHMENT_TTL_SECONDS=86400
