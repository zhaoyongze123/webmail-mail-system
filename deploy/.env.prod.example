APP_ENV=production
APP_NAME=webmail-mvp
APP_SECRET_KEY=replace-me
SESSION_COOKIE_SECURE=true
ADMIN_JWT_SECRET=replace-me

POSTGRES_DB=webmail
POSTGRES_USER=webmail
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://webmail:replace-me@postgres:5432/webmail

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

BACKEND_PORT=8000
FRONTEND_PORT=5173

MAIL_DIRECTORY_BACKEND=sqlite_vmail
MAIL_DIRECTORY_SQLITE_PATH=/var/vmail/vmail.db
MAIL_DIRECTORY_PASSWORD_MODE=plain
MAIL_QUOTA_ENABLED=true

MAIL_IMAP_HOST=14.103.117.188
MAIL_IMAP_PORT=143
MAIL_IMAP_SSL=false
MAIL_IMAP_STARTTLS=false
MAIL_SMTP_HOST=14.103.117.188
MAIL_SMTP_PORT=25
MAIL_SMTP_SSL=false
MAIL_SMTP_STARTTLS=false

CORS_ORIGINS=https://your-domain.example

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-me

# 生产部署时至少填一套镜像源；默认建议先用 GHCR
BACKEND_IMAGE=ghcr.io/zhaoyongze123/webmail-mail-system/backend:latest
FRONTEND_IMAGE=ghcr.io/zhaoyongze123/webmail-mail-system/frontend:latest

# 如果要强制走阿里云 ACR，可改成：
# BACKEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-namespace/webmail-mail-system/backend:latest
# FRONTEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-namespace/webmail-mail-system/frontend:latest
